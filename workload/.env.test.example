# Microsoft Fabric Workload Environment Configuration — Test
# Observability Workbench

##########################################################
# Workload Configuration
##########################################################
WORKLOAD_HOSTING_TYPE=FERemote
WORKLOAD_VERSION=1.100
WORKLOAD_NAME=Org.ObservabilityWorkbench
ITEM_NAMES=WorkbenchDashboard,AlertRule,SLODefinition

##########################################################
# Frontend Configuration
##########################################################
# Replace with your test environment Entra app registration client ID
FRONTEND_APPID=<YOUR_TEST_ENTRA_APP_ID>
# The base URL of the Frontend application in test environment
FRONTEND_URL=https://obs-workbench-test.azurewebsites.net
ENVIRONMENT_DISPLAY_NAME_SUFFIX=(Test)

##########################################################
# Backend Service Configuration
##########################################################
BACKEND_APPID=

##########################################################
# Environment Configuration
##########################################################
LOG_LEVEL=info

##########################################################
# Development Configuration
##########################################################
ENABLE_MEMORY_MONITORING=false
ENABLE_PLAYGROUND=false
