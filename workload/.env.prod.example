# Microsoft Fabric Workload Environment Configuration — Production
# Observability Workbench

##########################################################
# Workload Configuration
##########################################################
WORKLOAD_HOSTING_TYPE=FERemote
WORKLOAD_VERSION=1.100
WORKLOAD_NAME=Org.ObservabilityWorkbench
ITEM_NAMES=WorkbenchDashboard,AlertRule,SLODefinition

##########################################################
# Frontend Configuration
##########################################################
# Replace with your production Entra app registration client ID
FRONTEND_APPID=<YOUR_PROD_ENTRA_APP_ID>
# The base URL of the Frontend application in production
FRONTEND_URL=https://obs-workbench.azurewebsites.net
ENVIRONMENT_DISPLAY_NAME_SUFFIX=

##########################################################
# Backend Service Configuration
##########################################################
BACKEND_APPID=

##########################################################
# Environment Configuration
##########################################################
LOG_LEVEL=warn

##########################################################
# Development Configuration
##########################################################
ENABLE_MEMORY_MONITORING=false
ENABLE_PLAYGROUND=false
