{
  "name": "@kane-ai/observability-workbench-workload",
  "version": "1.0.0",
  "description": "Observability Workbench - Microsoft Fabric Workload Frontend",
  "private": true,
  "scripts": {
    "start": "npm run start:devServer",
    "start:devServer": "set NODE_OPTIONS=--max-old-space-size=8192 && env-cmd -f .env.dev webpack serve --open --config ./devServer/webpack.dev.js",
    "start:codespace": "node --max-old-space-size=8192 ./node_modules/.bin/env-cmd -f .env.dev webpack serve --open --config ./devServer/webpack.dev.js --no-hot",
    "build:test": "env-cmd -f .env.test webpack --config ./webpack.config.js --output-path ../build/Frontend --progress",
    "build:prod": "env-cmd -f .env.prod webpack --config ./webpack.config.js --output-path ../build/Frontend --mode production --progress",
    "build": "env-cmd -f .env webpack --config ./webpack.config.js --output-path ./dist --progress"
  },
  "author": "AI Agency",
  "license": "ISC",
  "dependencies": {
    "@fluentui/react": "^8.110.7",
    "@fluentui/react-components": "^9.7.2",
    "@fluentui/react-icons": "2.0.226",
    "@ms-fabric/workload-client": "^3.0.0",
    "@reduxjs/toolkit": "^2.6.0",
    "history": "^4.9.0",
    "i18next": "^25.4.1",
    "i18next-http-backend": "^2.4.2",
    "jwt-decode": "^3.1.2",
    "process": "^0.11.10",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^15.0.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^5.3.4",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-router-dom": "^5.3.2",
    "ajv": "^8.12.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^10.0.0",
    "css-loader": "^6.5.1",
    "dotenv": "^16.4.5",
    "env-cmd": "^10.1.0",
    "html-webpack-plugin": "^5.5.0",
    "sass": "^1.79.3",
    "sass-loader": "^16.0.2",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.2.6",
    "typescript": "^5.0.4",
    "webpack": "^5.90.3",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.7.0",
    "webpack-merge": "^6.0.1"
  }
}
