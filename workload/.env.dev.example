# Microsoft Fabric Workload Environment Configuration — Development
# Observability Workbench

##########################################################
# Workload Configuration
##########################################################
# Workload Hosting Type (FERemote or Remote depending on your scenario)
# At the moment only FERemote Hosting type is supported
WORKLOAD_HOSTING_TYPE=FERemote
# Workload Version
WORKLOAD_VERSION=1.100
# The workload name should be aligned with the name defined in the WorkloadManifest.xml
WORKLOAD_NAME=Org.ObservabilityWorkbench
# The default item names for the workload (comma-separated)
ITEM_NAMES=WorkbenchDashboard,AlertRule,SLODefinition

##########################################################
# Frontend Configuration
##########################################################
# Azure AD configuration for the frontend application
# Replace with your Entra app registration client ID
FRONTEND_APPID=<YOUR_DEV_ENTRA_APP_ID>
# The base URL of the Frontend application
FRONTEND_URL=http://localhost:60006
# Suffix for display names to differentiate dev from other environments
ENVIRONMENT_DISPLAY_NAME_SUFFIX=(Dev)

##########################################################
# Backend Service Configuration
# (optional only needed if you use Remote Hosting type)
##########################################################
# Azure AD configuration for the backend service
BACKEND_APPID=

##########################################################
# Environment Configuration
##########################################################
# The log level that should be used for the project
LOG_LEVEL=debug

##########################################################
# Development Configuration
##########################################################
# Enable memory monitoring during development (true/false)
ENABLE_MEMORY_MONITORING=true
# Enable playground routes in development
ENABLE_PLAYGROUND=true
