# Fabric Deployment Configuration — Production
# Copy to .fabric-deploy.prod.env and fill in values

# Required: Azure AD / Entra credentials
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=

# Workspace configuration
FABRIC_WORKSPACE_NAME=ObservabilityWorkbench-Prod
FABRIC_KQL_ENDPOINT=
FABRIC_KQL_DATABASE=EH_Observability

# Notebook schedule configuration (cron expressions)
SCHEDULE_INGESTION=*/5 * * * *
SCHEDULE_CORRELATION=*/15 * * * *
SCHEDULE_ALERTS=*/30 * * * *
